# print avg hours per week of project
# print_view_week_avg
# IN: a view: (project, avg_hours_week, total_hours, num_weeks, from_date, to_date)

# Parse command line arguments and call appropiate function
parse_args() {
  if [[ $1 == 'week' ]]; then
    query_project=$2
    view=
    make_sessions
    view_week_avg=make_view__by_project__total_time_by_week sessions query_project
    print_view_week_avg view_week_avg
  fi
  return 0
}

# parse_args $1 $2
make_sessions

#!/usr/bin/env bash

# script to alleviate friction in this workflow:
# - be doing something
# - "how do I {do this in typst/bash/whatever}?"

# it would be nice to be able to easily search through dev notes at this point.

# here's ppl talking about searching both filenames and contents
# https://github.com/junegunn/fzf/issues/2789

SEARCH_PATH=${1:-$DEV_DOCS}
SEARCH_PATH=${SEARCH_PATH:-"/home/tom/docs"}

_search() {
  cd "$SEARCH_PATH" || exit
  # 1. Search for text in files using Ripgrep
  # 2. Interactively restart Ripgrep with reload action
  # 3. Open the file in Vim
  RG_PREFIX="rg --column --line-number --no-heading --color=always --smart-case "
  INITIAL_QUERY="${*:-}"
  fzf --ansi --disabled --query "$INITIAL_QUERY" \
    --bind "start:reload:$RG_PREFIX {q} . || true" \
    --bind "change:reload:sleep 0.1; $RG_PREFIX {q} . || true" \
    --delimiter ":" \
    --cycle \
    --with-nth 1,2,4 \
    --layout=reverse \
    --border=rounded \
    --color='bg+:#333c43,bg:-1,hl:yellow,fg:-1,header:green,info:cyan,pointer:yellow,marker:yellow,fg+:white,prompt:cyan,hl+:yellow:underline' \
    --preview 'bat --theme="zenburn" --color=always {1} --highlight-line {2}' \
    --preview-window 'right,60%,border-left,+{2}+3/3,~3' \
    --bind 'enter:become(nvim {1} +{2})' \
    --bind "alt-n:down,alt-p:up"
}
# --color="bg+:#32302f,bg:#282828,hl:#d79921,fg" \
# --preview-window 'up,60%,border-bottom,+{2}+3/3,~3' \

# check if launched from term or via hotkey
# method: is stdin attached to term?
if [ -t 0 ]; then
  # I am already in a terminal, just run.
  _search "$@" && exit 0

else
  # I am floating in the void, launch a terminal + myself.
  st -t "The Brain" -c "brain" -g 140x40 -e "$0" "$@" && exit 0
fi

echo 'ERROR'
exit 1

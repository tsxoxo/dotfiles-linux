#     # Try to find the keyboard for up to 10 seconds
#     for i in {1..20}; do
#         APPLE_ID=$(xinput list --id-only "Apple Inc. Apple Internal Keyboard / Trackpad" 2>/dev/null)
#         if [ -n "$APPLE_ID" ]; then
#             setxkbmap -device "$APPLE_ID" realprog
#             break
#         fi
#         sleep 0.5
